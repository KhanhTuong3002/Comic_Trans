<Window x:Class="ComicTrans.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Comic Translator"
        Icon="/orca.png"
        Width="1400"
        Height="900"
        KeyDown="Window_KeyDown">

    <DockPanel>

        <!-- Thanh công cụ -->
        <ToolBar DockPanel.Dock="Top">

            <Button x:Name="btnNew"
                    Width="90"
                    Margin="5"
                    Content="New" Click="btnNew_Click"/>

            <Button x:Name="btnOpen"
                    Width="90"
                    Margin="5"
                    Content="Tải ảnh " Click="btnOpen_Click"/>

          
            <Button x:Name="btnOCR" 
                    Width="90"
                    Margin="5"
                    Content="Quét văn bản" Click="Button_Click"/>

            <ToggleButton x:Name="btnManualOcr"
                          Width="110"
                          Margin="5"
                          Content="Quét thủ công"/>

            <Button x:Name="btnTranslate"
                    Width="90"
                    Margin="5"
                    Content="Dịch" Click="btnTranslate_Click"/>

            <Button x:Name="btnReplace"
                    Width="90"
                    Margin="5"
                    Content="Thay thế" Click="btnReplace_Click"/>

            <Button x:Name="btnExport"
                    Width="90"
                    Margin="5"
                    Content="Export" Click="btnExport_Click"/>

            <Separator/>

            <Label Content="Nguồn:" VerticalAlignment="Center" Margin="5,0,0,0"/>
            <ComboBox x:Name="cbSourceLang" Width="120" Margin="5" SelectedIndex="0">
                <ComboBoxItem Content="Tiếng Anh (en)" Tag="en"/>
                <ComboBoxItem Content="Tiếng Nhật (japan)" Tag="japan"/>
                <ComboBoxItem Content="Tiếng Trung (ch)" Tag="ch"/>
                <ComboBoxItem Content="Tiếng Hàn (korean)" Tag="korean"/>
                <ComboBoxItem Content="Tiếng Việt (vi)" Tag="vi"/>
            </ComboBox>

            <Separator/>


        </ToolBar>

        <!-- StatusBar ở dưới cùng -->
        <StatusBar DockPanel.Dock="Bottom" Height="30">
            <StatusBarItem Margin="5,0,0,0">
                <TextBlock x:Name="txtStatus" Text="Ready" VerticalAlignment="Center"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right" Margin="0,0,5,0">
                <ProgressBar x:Name="pbProgress" Width="150" Height="15" Minimum="0" Maximum="100" Visibility="Collapsed" VerticalAlignment="Center"/>
            </StatusBarItem>
        </StatusBar>

        <Grid>

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="250"/>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="300"/>

            </Grid.ColumnDefinitions>

            <!-- Panel trái -->
            <Border Grid.Column="0"
                    BorderBrush="Gray"
                    BorderThickness="1">

                <DockPanel Margin="10">

                    <TextBlock DockPanel.Dock="Top"
                               FontWeight="Bold"
                               FontSize="18"
                               Margin="0,0,0,10"
                               Text="Pages"/>

                    <ListBox x:Name="lbPages"
                             SelectionChanged="lbPages_SelectionChanged"
                             AllowDrop="True"
                             Drop="lbPages_Drop"
                             DragOver="lbPages_DragOver"
                             PreviewMouseLeftButtonDown="lbPages_PreviewMouseLeftButtonDown"
                             MouseMove="lbPages_MouseMove"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="3" Background="Transparent">
                                    <Grid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Quét lại trang này (Force OCR)" Click="MenuForceOcr_Click"/>
                                            <MenuItem Header="Dịch lại trang này (Force Translate)" Click="MenuForceTranslate_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Xóa kết quả (Clear)" Click="MenuClearResults_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Xóa trang này (Delete)" Click="MenuDeletePage_Click"/>
                                        </ContextMenu>
                                    </Grid.ContextMenu>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border BorderThickness="1" BorderBrush="#CCCCCC" CornerRadius="2">
                                        <Image Source="{Binding Thumbnail}" 
                                               Width="44" 
                                               Height="60" 
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="LowQuality"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding PageNumber, StringFormat='Trang {0}'}" 
                                                   FontWeight="Bold" 
                                                   Foreground="#009688"
                                                   FontSize="11"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding PageName}" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="2"/>
                                <Setter Property="Margin" Value="1"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="OnPreviewMouseRightButtonDown" />
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E0F2F1"/>
                                        <Setter Property="BorderBrush" Value="#009688"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                </DockPanel>

            </Border>

            <!-- Ảnh -->
            <Border Grid.Column="1"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    ClipToBounds="True">

                <Grid>
                    <ScrollViewer x:Name="imageScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="#F5F5F7"
                                  Focusable="False"
                                  PreviewMouseWheel="imageScrollViewer_PreviewMouseWheel"
                                  PreviewMouseDown="imageScrollViewer_PreviewMouseDown"
                                  PreviewMouseMove="imageScrollViewer_PreviewMouseMove"
                                  PreviewMouseUp="imageScrollViewer_PreviewMouseUp"
                                  SizeChanged="imageScrollViewer_SizeChanged">
                        
                        <Grid x:Name="imageContainer"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <Grid.LayoutTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="imgScaleTransform" ScaleX="1.0" ScaleY="1.0"/>
                                </TransformGroup>
                            </Grid.LayoutTransform>

                            <Image x:Name="imgComic"
                                   Width="{Binding ElementName=overlayCanvas, Path=Width}"
                                   Height="{Binding ElementName=overlayCanvas, Path=Height}"
                                   Stretch="Fill"/>

                            <Canvas x:Name="overlayCanvas"
                                    Background="Transparent"
                                    IsHitTestVisible="True"
                                    MouseRightButtonDown="overlayCanvas_MouseRightButtonDown"
                                    MouseRightButtonUp="overlayCanvas_MouseRightButtonUp"
                                    MouseMove="overlayCanvas_MouseMove"
                                    MouseLeftButtonDown="overlayCanvas_MouseLeftButtonDown"/>

                        </Grid>
                    </ScrollViewer>

                    <!-- Floating Zoom Controller (Glassmorphism card) -->
                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="15"
                            Background="#D9FFFFFF"
                            BorderBrush="#1A000000"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="4,2,4,2"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="#000000"/>
                        </Border.Effect>
                        <Border.Resources>
                            <Style x:Key="ZoomButtonStyle" TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Width" Value="32"/>
                                <Setter Property="Height" Value="32"/>
                                <Setter Property="Margin" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="16">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#E0EBF5"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#C2D7EC"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Border.Resources>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource ZoomButtonStyle}"
                                    Content="➖"
                                    ToolTip="Thu nhỏ (Ctrl + Cuộn chuột xuống)"
                                    Click="btnZoomOut_Click"/>
                            <TextBlock x:Name="txtZoomPercent"
                                       Text="100%"
                                       Width="48"
                                       FontWeight="Bold"
                                       FontSize="11"
                                       Foreground="#2C3E50"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"/>
                            <Button Style="{StaticResource ZoomButtonStyle}"
                                    Content="➕"
                                    ToolTip="Phóng to (Ctrl + Cuộn chuột lên)"
                                    Click="btnZoomIn_Click"/>
                            <Separator Width="1" Height="20" Margin="4,0,4,0" Background="#1A000000"/>
                            <Button Style="{StaticResource ZoomButtonStyle}"
                                    Content="⛶"
                                    ToolTip="Vừa màn hình (Ctrl + 0)"
                                    Click="btnZoomFit_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>

            </Border>

            <!-- Panel phải -->
            <Border Grid.Column="2"
        BorderBrush="Gray"
        BorderThickness="1">

                <DockPanel>

                    <TextBlock DockPanel.Dock="Top"
                    Margin="10"
                    FontWeight="Bold"
                    FontSize="18"
                    Text="Result"/>

                    <ListView x:Name="lvOcrResult"
                              SelectionChanged="lvOcrResult_SelectionChanged"
                              HorizontalContentAlignment="Stretch"
                              AllowDrop="True"
                              PreviewMouseLeftButtonDown="lvOcrResult_PreviewMouseLeftButtonDown"
                              MouseMove="lvOcrResult_MouseMove"
                              DragOver="lvOcrResult_DragOver"
                              Drop="lvOcrResult_Drop">

                        <ListView.View>

                            <GridView>

                                <GridViewColumn Header="Text" Width="280">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     GotFocus="TextBox_GotFocus"
                                                     BorderThickness="1"
                                                     BorderBrush="#E0E0E0"
                                                     Padding="4"
                                                     Margin="1"
                                                     Width="260"
                                                     MinHeight="30"
                                                     VerticalScrollBarVisibility="Auto">
                                                <TextBox.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Command="Copy" Header="Sao chép"/>
                                                        <MenuItem Command="Cut" Header="Cắt"/>
                                                        <MenuItem Command="Paste" Header="Dán"/>
                                                        <Separator/>
                                                        <MenuItem Header="Xóa kết quả OCR này" Click="MenuDeleteOcr_Click"/>
                                                    </ContextMenu>
                                                </TextBox.ContextMenu>
                                            </TextBox>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                            </GridView>

                        </ListView.View>

                    </ListView>

                </DockPanel>

            </Border>

        </Grid>

    </DockPanel>

</Window>